# ==========================================
# TradeLoop — Environment Variables
# ==========================================
# Copy this file to .env and fill in values.
# For production, all REQUIRED vars must be set.

# --- REQUIRED ---

# Generate with: openssl rand -hex 32
# Production WILL NOT START without a real key.
SECRET_KEY=generate-with-openssl-rand-hex-32

# Database URL
# Local dev: sqlite+aiosqlite:///./tradeloop.db
# Production: postgresql+asyncpg://user:pass@host:5432/tradeloop
DATABASE_URL=sqlite+aiosqlite:///./tradeloop.db

# "development" or "production"
# Production enforces SECRET_KEY + blocks payment dev bypass.
ENVIRONMENT=development

# Frontend URL (used for CORS, email links, etc.)
# Must match EXACTLY where your frontend is hosted.
FRONTEND_URL=http://localhost:5173

# --- PAYMENTS (Razorpay) ---
# Required for paid plans in production.
# Without these, payment endpoints return 503 in production.
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=

# --- EMAIL (Resend) ---
# Without this, emails are logged to console (dev mode).
RESEND_API_KEY=

# --- MONITORING ---
# Sentry DSN for error tracking (optional, recommended for production)
SENTRY_DSN=

# PostHog API key for product analytics (optional)
POSTHOG_API_KEY=

# --- TUNING ---
# FREE_TIER_TRADE_LIMIT=50
# MAX_UPLOAD_SIZE_BYTES=5242880
# ACCESS_TOKEN_EXPIRE_MINUTES=1440
# REFRESH_TOKEN_EXPIRE_DAYS=30
